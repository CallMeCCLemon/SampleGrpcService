#!/usr/bin/env bash
# Pre-commit hook: gate commits on lint and compile errors in newly changed code.
#
# Enable once per clone:
#   make hooks-install   # or: git config core.hooksPath .githooks
#
# Skip a single commit with `git commit --no-verify` if you need to.

set -euo pipefail

# Run from the repo root regardless of where git invoked us.
cd "$(git rev-parse --show-toplevel)"

# `lint-new` only flags issues on lines changed vs HEAD — fast and focused on
# what's actually about to be committed.
make lint-new

# Catch compile errors before they hit CI.
go build ./...
